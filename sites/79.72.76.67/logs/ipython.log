2026-04-12 10:59:40,262 INFO ipython === bench console session ===
2026-04-12 10:59:40,262 INFO ipython import frappe

DEPT = "Day Team - CHAN RICH"
day_team = frappe.get_all("Employee",
    filters={"status": "Active", "department": DEPT},
    fields=["name", "employee_name", "default_shift"]
)
print(f"Found {len(day_team)} Day Team employees")

for emp in day_team:
    assignments = frappe.get_all("Shift Assignment",
        filters={"employee": emp.name, "docstatus": 1},
        fields=["name", "shift_type"]
    )

    for a in assignments:
        try:
            # Step 1: Find linked Employee Checkins and unlink them
            linked_checkins = frappe.get_all("Employee Checkin",
                filters={"shift_assignment": a.name},
                fields=["name"]
            )
            for ck in linked_checkins:
                frappe.db.set_value("Employee Checkin", ck.name, {
                    "shift_assignment": None,
                    "shift_type": None,
                    "shift_actual_start": None,
                    "shift_actual_end": None
                }, update_modified=False)
                print(f"  [UNLINKED] Checkin {ck.name} from {a.name}")
            frappe.db.commit()

            # Step 2: Now cancel the shift assignment
            doc = frappe.get_doc("Shift Assignment", a.name)
            doc.cancel()
            frappe.db.commit()
            print(f"  [CANCELLED] {emp.employee_name} | {a.shift_type}")

        except Exception as e:
            print(f"  [ERROR] {emp.employee_name} | {a.name}: {e}")

    # Step 3: Clear default shift on employee
    if emp.default_shift:
        edoc = frappe.get_doc("Employee", emp.name)
        edoc.default_shift = ""
        edoc.save(ignore_permissions=True)
        frappe.db.commit()
        print(f"  [CLEARED] {emp.employee_name} default shift")

print("Done!")
