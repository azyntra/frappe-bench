2026-04-11 17:39:26,057 INFO ipython === bench console session ===
2026-04-11 17:39:26,057 INFO ipython import frappe

COMPANY   = "CHAN RICH FRUITS (PVT) LTD"
FROM_DATE = "2026-01-01"
TO_DATE   = "2026-12-31"

LEAVE_TYPES = [
    ("Annual Leave", 14),
    ("Casual Leave",  7),
]

employees = frappe.get_all("Employee",
    filters={"status": "Active"},
    fields=["name", "employee_name", "date_of_joining"]
)

print(f"Found {len(employees)} employees\n")

for leave_type, days in LEAVE_TYPES:
    print(f"--- {leave_type} ({days} days) ---")
    for emp in employees:
        # Use joining date if later than FROM_DATE
        from_date = FROM_DATE
        if emp.date_of_joining and str(emp.date_of_joining) > FROM_DATE:
            from_date = str(emp.date_of_joining)

        # Skip if already allocated
        exists = frappe.db.exists("Leave Allocation", {
            "employee": emp.name,
            "leave_type": leave_type,
            "docstatus": ["!=", 2]
        })
        if exists:
            print(f"  [SKIP] {emp.employee_name}")
            continue

        try:
            doc = frappe.get_doc({
                "doctype": "Leave Allocation",
                "employee": emp.name,
                "employee_name": emp.employee_name,
                "leave_type": leave_type,
                "from_date": from_date,
                "to_date": TO_DATE,
                "new_leaves_allocated": days,
                "company": COMPANY,
            })
            doc.insert(ignore_permissions=True)
            doc.submit()
            frappe.db.commit()
            print(f"  [OK] {emp.employee_name} — {days} days")
        except Exception as e:
            print(f"  [ERROR] {emp.employee_name}: {e}")
            frappe.db.rollback()

print("\nDone!")
